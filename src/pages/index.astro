---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";

const { entries: products, cacheHint } = await getEmDashCollection("products");

Astro.cache.set(cacheHint);

// Gallery images seeded into R2 from source URLs
const galleryImages = [
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/menu-image-3.jpg", alt: "Bakery selection" },
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/menu-image-2.jpg", alt: "Fresh pastries" },
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/menu-image-1.jpg", alt: "Cakes display" },
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/about-image-5.jpg", alt: "Baking in progress" },
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/contact-image-1.jpg", alt: "Bakery storefront" },
	{ src: "https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/about-image-3.jpg", alt: "Artisan baked goods" },
];

// Featured product spotlight
const spotlightProduct = products.find((p) => p.id === "product-five");
---

<Base title="Lucy's Bakery" description="The Most Delicious Baked Goods You've Ever Had">
	<!-- Hero -->
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-title">The Most Delicious<br />Baked Goods<br />You've Ever Had</h1>
			<a href="/shop" class="hero-cta">Shop Baked Goods</a>
		</div>
	</section>

	<!-- Product Grid -->
	<section class="products-section">
		<div class="products-inner">
			{
				products.length === 0 ? (
					<div class="empty-state">
						<p>No products yet. Add products in the admin panel.</p>
						<a href="/_emdash/admin/content/products/new" class="btn">Add a product</a>
					</div>
				) : (
					<div class="products-grid">
						{products.map((product) => (
							<ProductCard
								title={product.data.title ?? "Untitled"}
								price={product.data.price ?? ""}
								featuredImage={product.data.featured_image}
								href={`/shop/${product.id}`}
							/>
						))}
					</div>
				)
			}
		</div>
	</section>

	<!-- Feature Blurbs -->
	<section class="features-section">
		<div class="features-inner">
			<div class="features-image">
				<img
					src="https://v7s.f09.myftpupload.com/wp-content/uploads/2023/02/home-image-4.jpg"
					alt="Freshly baked goods"
					loading="lazy"
				/>
			</div>
			<div class="features-text">
				<div class="feature">
					<h3 class="feature-title">Homemade</h3>
					<p>I approach baking with an emphasis on family-friendly snacks and the tastiest ways to eat healthy! When not in my kitchen, I'm often hiking in the mountains around my home and exploring the best food spots.</p>
				</div>
				<div class="feature">
					<h3 class="feature-title">Food + People</h3>
					<p>Food has a special ability to bring people together. I hope you will find that this online community feels just as welcoming as a real kitchen. For me, baking together builds the best communities, let's get baking!</p>
				</div>
				<div class="feature">
					<h3 class="feature-title">Homegrown</h3>
					<p>I have been baking for a long time, but that doesn't mean that you need a ton of experience to follow my recipes. I work to make my recipes interesting for advanced bakers but still accessible for beginners.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Info Bar -->
	<section class="info-section">
		<div class="info-inner">
			<div class="info-address">
				<h4>Lucy's Bakery</h4>
				<p>123 Example Rd, Scottsdale, AZ 85260</p>
				<p>(555) 555-5555</p>
			</div>
			<div class="info-hours">
				<h4>Our Hours</h4>
				<p>Monday – Friday: 7am – 8pm</p>
				<p>Saturday: 8am – 7pm</p>
			</div>
			<blockquote class="info-quote">
				<p>The best bakery in town</p>
			</blockquote>
		</div>
	</section>

	<!-- Gallery -->
	<section class="gallery-section">
		<div class="gallery-grid">
			{galleryImages.map((img) => (
				<div class="gallery-item">
					<img src={img.src} alt={img.alt} loading="lazy" />
				</div>
			))}
		</div>
	</section>

	<!-- Product Spotlight -->
	{
		spotlightProduct && (
			<section class="spotlight-section">
				<div class="spotlight-inner">
					<div class="spotlight-image">
						<Image image={spotlightProduct.data.featured_image} />
					</div>
					<div class="spotlight-content">
						<h2 class="spotlight-title">{spotlightProduct.data.title}</h2>
						<p class="spotlight-description">{spotlightProduct.data.description}</p>
						<p class="spotlight-price">{spotlightProduct.data.price}</p>
						<a href={`/shop/${spotlightProduct.id}`} class="spotlight-cta">
							Shop now
						</a>
					</div>
				</div>
			</section>
		)
	}
</Base>

<style>
	/* ── Hero ── */
	.hero {
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
		padding: var(--spacing-24) var(--spacing-6);
		text-align: center;
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-8);
	}

	.hero-title {
		font-size: clamp(var(--font-size-3xl), 6vw, var(--font-size-5xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	.hero-cta {
		display: inline-block;
		padding: var(--spacing-4) var(--spacing-8);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		transition: background var(--transition-fast);
	}

	.hero-cta:hover {
		background: var(--color-accent-hover);
		color: var(--color-on-accent);
	}

	/* ── Products Grid ── */
	.products-section {
		padding: var(--spacing-16) var(--spacing-6);
	}

	.products-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.products-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-6);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-16) 0;
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	/* ── Feature Blurbs ── */
	.features-section {
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
		padding: var(--spacing-16) var(--spacing-6);
	}

	.features-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: var(--spacing-12);
		align-items: center;
	}

	.features-image img {
		width: 100%;
		height: 400px;
		object-fit: cover;
		border-radius: var(--radius-lg);
	}

	.features-text {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-8);
	}

	.feature-title {
		font-size: var(--font-size-lg);
		font-weight: 600;
		margin-bottom: var(--spacing-3);
	}

	.feature p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	/* ── Info Bar ── */
	.info-section {
		padding: var(--spacing-12) var(--spacing-6);
	}

	.info-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-8);
		align-items: start;
	}

	.info-address h4,
	.info-hours h4 {
		font-size: var(--font-size-sm);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		margin-bottom: var(--spacing-3);
		color: var(--color-muted);
	}

	.info-address p,
	.info-hours p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	.info-quote {
		border-left: 3px solid var(--color-accent);
		padding-left: var(--spacing-6);
		margin: 0;
	}

	.info-quote p {
		font-size: var(--font-size-xl);
		font-style: italic;
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	/* ── Gallery ── */
	.gallery-section {
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
		padding: var(--spacing-6) 0;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
	}

	.gallery-item {
		aspect-ratio: 1;
		overflow: hidden;
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	/* ── Spotlight ── */
	.spotlight-section {
		padding: var(--spacing-16) var(--spacing-6);
	}

	.spotlight-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-12);
		align-items: center;
	}

	.spotlight-image img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius-lg);
	}

	.spotlight-content {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
	}

	.spotlight-title {
		font-size: var(--font-size-3xl);
		font-weight: 700;
		line-height: var(--leading-tight);
	}

	.spotlight-description {
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	.spotlight-price {
		font-size: var(--font-size-2xl);
		font-weight: 600;
	}

	.spotlight-cta {
		display: inline-block;
		align-self: flex-start;
		padding: var(--spacing-3) var(--spacing-8);
		border: 2px solid var(--color-text);
		color: var(--color-text);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
		transition:
			background var(--transition-fast),
			color var(--transition-fast);
	}

	.spotlight-cta:hover {
		background: var(--color-text);
		color: var(--color-bg);
	}

	/* ── Responsive ── */
	@media (max-width: 1100px) {
		.products-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 900px) {
		.features-inner {
			grid-template-columns: 1fr;
		}

		.features-text {
			grid-template-columns: 1fr;
			gap: var(--spacing-6);
		}

		.features-image img {
			height: 260px;
		}

		.info-inner {
			grid-template-columns: 1fr 1fr;
		}

		.info-quote {
			grid-column: span 2;
		}

		.products-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.gallery-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.spotlight-inner {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}

	@media (max-width: 600px) {
		.hero {
			padding: var(--spacing-16) var(--spacing-4);
		}

		.products-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-4);
		}

		.info-inner {
			grid-template-columns: 1fr;
		}

		.info-quote {
			grid-column: span 1;
		}

		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>

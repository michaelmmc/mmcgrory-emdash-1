---
import { getEmDashEntry } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: product, cacheHint } = await getEmDashEntry("products", slug);

if (!product) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
---

<Base
	title={product.data.title ?? "Product"}
	content={{ collection: "products", id: product.data.id, slug }}
>
	<div class="product-page">
		<nav class="breadcrumb">
			<a href="/shop">Shop</a>
			<span class="breadcrumb-sep">/</span>
			<span>{product.data.title}</span>
		</nav>

		<div class="product-layout">
			<div class="product-image-col">
				{
					product.data.featured_image ? (
						<div class="product-image">
							<Image image={product.data.featured_image} />
						</div>
					) : (
						<div class="product-image-placeholder" />
					)
				}
			</div>

			<div class="product-details">
				<h1 class="product-title" {...product.edit.title}>
					{product.data.title}
				</h1>

				{product.data.price && (
					<p class="product-price">{product.data.price}</p>
				)}

				{product.data.description && (
					<p class="product-description">{product.data.description}</p>
				)}

				<!-- Display-only add to cart (no functional cart) -->
				<div class="product-actions">
					<div class="quantity-control">
						<label for="qty" class="qty-label">Quantity</label>
						<input
							type="number"
							id="qty"
							name="qty"
							min="1"
							value="1"
							class="qty-input"
						/>
					</div>
					<button type="button" class="add-to-cart-btn" disabled>
						Add to cart
					</button>
				</div>

				<p class="display-only-note">
					Online ordering coming soon. Visit us in store at 123 Example Rd, Scottsdale, AZ.
				</p>

				{product.data.detail_description && (
					<div class="product-body">
						<h2 class="product-body-heading">Description</h2>
						<PortableText value={product.data.detail_description} />
					</div>
				)}
			</div>
		</div>
	</div>
</Base>

<style>
	.product-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-8);
	}

	.breadcrumb a {
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.breadcrumb a:hover {
		color: var(--color-text);
	}

	.breadcrumb-sep {
		color: var(--color-border);
	}

	/* Two-column layout */
	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
		align-items: start;
	}

	.product-image {
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
	}

	.product-image img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		display: block;
	}

	.product-image-placeholder {
		width: 100%;
		aspect-ratio: 1;
		background: var(--color-surface);
		border-radius: var(--radius-lg);
	}

	/* Product details */
	.product-details {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
	}

	.product-title {
		font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
	}

	.product-price {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		color: var(--color-text);
	}

	.product-description {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	/* Add to cart (display only) */
	.product-actions {
		display: flex;
		align-items: flex-end;
		gap: var(--spacing-4);
		padding-top: var(--spacing-2);
	}

	.quantity-control {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.qty-label {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.qty-input {
		width: 72px;
		padding: var(--spacing-3) var(--spacing-3);
		font-size: var(--font-size-base);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
		text-align: center;
	}

	.add-to-cart-btn {
		padding: var(--spacing-3) var(--spacing-8);
		background: var(--color-text);
		color: var(--color-bg);
		border: none;
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		cursor: not-allowed;
		opacity: 0.5;
		font-family: var(--font-sans);
	}

	.display-only-note {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-style: italic;
	}

	/* Detail body */
	.product-body {
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.product-body-heading {
		font-size: var(--font-size-sm);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.product-body :global(p) {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin-bottom: 1em;
	}

	@media (max-width: 768px) {
		.product-layout {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}
</style>
